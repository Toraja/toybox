{
  "print": {
    "prefix": "pr",
    "body": [
      "print!(\"${1:msg: }${2:{\\}}\"${3:, ${4:args}});"
    ],
    "description": "print macro"
  },
  "println": {
    "prefix": "prl",
    "body": [
      "println!(\"${1:msg: }${2:{\\}}\"${3:, ${4:args}});"
    ],
    "description": "println macro"
  },
  "return": {
    "prefix": "re",
    "body": [
      "return"
    ],
    "description": "return"
  },
  "function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:arg})${3: -> ${4:RetType}} {",
      "\t${5:todo!();}",
      "}"
    ],
    "description": "function"
  },
  "method": {
    "prefix": "me",
    "body": [
      "fn ${1:name}(${2:&}self${3:, ${4:arg}})${5: -> ${6:RetType}} {",
      "\t${7:todo!();}",
      "}"
    ],
    "description": "method"
  },
  "trait method": {
    "prefix": "tme",
    "body": [
      "fn ${1:name}(${2:&}self${3:, ${4:arg}})${5: -> ${6:RetType}}"
    ],
    "description": "trait method"
  },
  "struct": {
    "prefix": "st",
    "body": [
      "struct ${1:Name} {",
      "\t${2:field}: ${3:Type},",
      "}"
    ],
    "description": "struct"
  },
  "enum": {
    "prefix": "en",
    "body": [
      "enum ${1:Name} {",
      "\t${2:Variant}(${3:Type}),",
      "}"
    ],
    "description": "enum"
  },
  "match Option": {
    "prefix": "matopt",
    "body": [
      "match ${1:expr} {",
      "\tSome(${2:expr}) => ${3:expr},",
      "\tNone => ${4:expr},",
      "}"
    ],
    "description": "match … { Some()…, None()… }"
  },
  "match Result": {
    "prefix": "matres",
    "body": [
      "match ${1:expr} {",
      "\tOk(${2:expr}) => ${3:expr},",
      "\tErr(e) => ${4:expr},",
      "}"
    ],
    "description": "match … { Ok()…, Err()… }"
  },
  "let match": {
    "prefix": "letmat",
    "body": [
      "let ${1:pat} = match ${2:expr} {",
      "\t${3:expr} => ${4:expr},",
      "}"
    ],
    "description": "let … match … { … }"
  },
  "let match Result": {
    "prefix": "letmatres",
    "body": [
      "let ${1:pat} = match ${2:expr} {",
      "\tOk(${3:expr}) => ${4:expr},",
      "\tErr(e) => ${5:expr},",
      "}"
    ],
    "description": "let … = match … { Ok()…, Err()… }"
  },
  "pub mod": {
    "prefix": "pmod",
    "body": [
      "pub mod ${1:name} {",
      "\t${2:${TM_SELECTED_TEXT}}",
      "}"
    ],
    "description": "pub mod … { … }"
  },
  "String from": {
    "prefix": "sf",
    "body": [
      "String::from(\"${1:str}\")"
    ],
    "description": "mod …;"
  },
  "From Trait": {
    "prefix": "from",
    "body": [
      "impl From<${1:Type}> for ${2:Type} {",
      "\tfn from(${3:arg}: ${1}) -> Self {",
      "\t    ${4:todo!();}",
      "\t}",
      "}"
    ],
    "description": "impl From<…> for … { … }"
  },
  "test module": {
    "prefix": "testmod",
    "body": [
      "#[cfg(test)]",
      "mod tests {",
      "\tuse super::*;",
      "",
      "\ttest${2}",
      "}"
    ],
    "description": "#[cfg(test)] mod tests …"
  },
  "tokio test": {
    "prefix": "ttest",
    "body": [
      "#[tokio::test]",
      "async fn ${1:test_function_name}() {",
      "\t${2:// code here}",
      "}"
    ],
    "description": "#[tokio::test] async fn …"
  }
}
