{
  "$schema": "https://opencode.ai/config.json",
  // custom povider example
  "provider": {
    "my-provider": {
      "npm": "@ai-sdk/openai-compatible", // npm package name of the provider SDK
      "name": "My AI",
      "options": {
        "baseURL": "https://api.my-ai.example/v1", // baseURL can only be set per provider, not per model
        "apiKey": "{env:MY_AI_API_KEY}", // load from environment variable
      },
      "models": {
        "my-model": {
          "name": "My Model",
          "limit": { // set token limits for this model
            "context": 1000000,
            "output": 65535
          },
        },
      },
    },
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "external_directory": "ask"
  },
  "mcp": {
    "glab": {
      "type": "local",
      "command": [
        "glab",
        "mcp",
        "serve"
      ],
      "enabled": false
    }
  }
}
