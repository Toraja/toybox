{
  "$schema": "https://opencode.ai/config.json",
  // custom provider example
  /*
  "provider": {
    "my-provider": {
      "npm": "@ai-sdk/openai-compatible", // npm package name of the provider SDK
      "name": "My AI",
      "options": {
        "baseURL": "https://api.my-ai.example/v1", // baseURL can only be set per provider, not per model
        "apiKey": "{env:MY_AI_API_KEY}", // load from environment variable
      },
      "models": {
        "my-model": {
          "name": "My Model",
          "limit": { // set token limits for this model
            "context": 1000000,
            "output": 65535
          },
        },
      },
    },
  },
  */
  "permission": {
    "edit": "ask",
    "bash": {
      // `*` must be appended to match the command with any arguments. For example, `git log --oneline` does not match `git log`, but DOES match `git log *`.
      // The commands after condition (&&/||) and pipe (|) are checked as well.
      "*": "ask",
      "cargo clippy *": "allow",
      "cargo fmt *": "allow",
      "cargo test *": "allow",
      "echo *": "allow",
      // "find *": "allow", // find can be dangerous if combined with -exec flag
      "git diff *": "allow",
      "git log *": "allow",
      "git remote show *": "allow",
      "git status *": "allow",
      "glab auth status": "allow",
      "glab issue list *": "allow",
      "glab issue view *": "allow",
      "grep *": "allow",
      "ls *": "allow",
      "mkdir *": "allow",
      "openspec *": "allow",
      "sort *": "allow",
      "which *": "allow",
    },
    "external_directory": "ask"
  },
  "mcp": {
    "glab": {
      "type": "local",
      "command": [
        "glab",
        "mcp",
        "serve"
      ],
      "enabled": false
    }
  }
}
